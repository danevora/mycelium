# Copy to .env.local and fill in.
# Vercel AI Gateway key — required for ingest + chat (routes the model call through
# the Gateway, where per-user usage tracking / billing margin lives later).
# Create one at https://vercel.com/dashboard -> AI Gateway. On Vercel deploys you can
# rely on OIDC instead of this key.
AI_GATEWAY_API_KEY=

# Optional: override the Gateway model slug (creator/model).
# Defaults to anthropic/claude-sonnet-4-6 — adjust if the Gateway catalog slug differs.
# MYCELIUM_MODEL=anthropic/claude-sonnet-4-6
