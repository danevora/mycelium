# Copy to .env.local and fill in. (.env.local is gitignored.)

# --- Database: Neon / Vercel Postgres ---
# Provision Postgres from the Vercel dashboard (Storage -> Neon). On Vercel the
# integration injects DATABASE_URL automatically. For local dev, paste the
# pooled connection string here, then run `npm run db:setup` once.
DATABASE_URL=

# --- Auth: Clerk ---
# Create an app at https://dashboard.clerk.com and copy both keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Billing: Clerk Billing (pro tier) ---
# Enable Billing in the Clerk dashboard and create a plan; its slug must match this.
# Pro unlocks multiple wikis (cap 5) and higher daily AI limits.
# CLERK_PRO_PLAN_SLUG=pro

# --- AI: Vercel AI Gateway ---
# Required for ingest + chat (routes the model call through the Gateway, where
# per-user usage tracking / billing margin lives later). On Vercel deploys you can
# rely on OIDC instead of this key. Create one at Vercel dashboard -> AI Gateway.
AI_GATEWAY_API_KEY=

# Optional: override the Gateway model slug (creator/model).
# Defaults to anthropic/claude-sonnet-4-6 — adjust if the Gateway catalog slug differs.
# MYCELIUM_MODEL=anthropic/claude-sonnet-4-6

# Optional: per-user daily quotas (cheap spend cap). Defaults shown. Limits are
# per-user (shared across a user's wikis); pro users get the higher PRO_* caps.
# DAILY_INGEST_LIMIT=20
# DAILY_CHAT_LIMIT=50
# PRO_DAILY_INGEST_LIMIT=200
# PRO_DAILY_CHAT_LIMIT=500
